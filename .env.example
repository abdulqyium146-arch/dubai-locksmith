# ─────────────────────────────────────────────────────────
# Car Key Service DXB — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────

# ── Supabase (Booking System + Admin Dashboard) ───────────
# Get these from: Supabase Dashboard → Project Settings → API
# ADD BOTH to Vercel: Settings → Environment Variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# Service role key — bypasses RLS for admin data access (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Admin Dashboard ────────────────────────────────────────
# Single password to access /admin — set to something only you know
ADMIN_PASSWORD=change_this_password

# ── Site ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.carkeyservicedxb.com
NEXT_PUBLIC_SITE_NAME="Car Key Service DXB"

# ── Business Contact ──────────────────────────────────────
NEXT_PUBLIC_PHONE=+97152817 6909
NEXT_PUBLIC_PHONE_DISPLAY="+971 52 817 6909"
NEXT_PUBLIC_EMAIL=info@carkeyservicedxb.com
NEXT_PUBLIC_WHATSAPP=971528176909

# ── Google Maps / Places ──────────────────────────────────
# Obtain from Google Cloud Console → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_server_api_key_here

# Google Place ID for the business (used to pull live reviews)
NEXT_PUBLIC_GOOGLE_PLACE_ID=ChIJ_placeholder_replace_with_real

# ── Analytics ─────────────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager Container ID (optional, alternative to GA4 direct)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Revalidation ─────────────────────────────────────────
# Secret token for on-demand ISR revalidation endpoint
REVALIDATE_SECRET=replace_with_a_long_random_string

# ── Contact Form / Email ──────────────────────────────────
# Resend API key for transactional email (https://resend.com)
RESEND_API_KEY=re_placeholder_replace_with_real

# Recipient email for contact form submissions
CONTACT_FORM_RECIPIENT=info@carkeyservicedxb.com

# ── Rate Limiting ─────────────────────────────────────────
# Upstash Redis REST URL & token (for edge rate limiting on API routes)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ── Deployment ────────────────────────────────────────────
# Set by Vercel automatically; override locally if needed
# VERCEL_URL=
# NODE_ENV=development
